APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080

GEMINI_API_KEY=
OPENAI_API_KEY=

GOOGLE_SA_FILE=/app/secrets/google_sa.json
GOOGLE_TEMPLATE_DOC_ID=
GOOGLE_CASES_PARENT_FOLDER_ID=

GEMINI_MODEL_VISION=models/gemini-2.5-flash
GEMINI_MODEL_TEXT=models/gemini-2.5-pro
OPENAI_MODEL=gpt-4.1

TEMPLATE_DOCX_PATH=app/templates/plantilla_notarial.docx
OUTPUT_DIR=outputs
PDF_ENGINE=libreoffice
RAG_STORE_DIR=app/rag_store
CORS_ALLOW_ORIGINS=http://localhost:5173

INTERNAL_ADMIN_TOKEN=
OPENCLAW_BASE_URL=http://host.docker.internal:18789
OPENCLAW_HOOK_TOKEN=
OPENCLAW_AGENT_HOOK_PATH=/hooks/agent
OPENCLAW_MAINTENANCE_MODEL=
OPENCLAW_MAINTENANCE_PROMPT_FILE=ops/openclaw/backend-maintenance-prompt.md
OPENCLAW_MAINTENANCE_WORKSPACE=/srv/notar-ia/backend/autotune
OPENCLAW_MAINTENANCE_LIVE_CHECKOUT=/srv/notar-ia/backend/current
OPENCLAW_MAINTENANCE_BRANCH=main
OPENCLAW_AUTO_TUNE_ENABLED=false
OPENCLAW_AUTO_TUNE_MIN_COMMENTS=1
OPENCLAW_AUTO_TUNE_GIT_PUSH_ENABLED=false
OPENCLAW_AUTO_TUNE_DEPLOY_ENABLED=false
OPENCLAW_AUTO_TUNE_DEPLOY_COMMAND=cd /srv/notar-ia/backend/current && git pull --ff-only origin main && docker build -t ghcr.io/andresca94/notarias-backend:latest . && docker compose -f /srv/notar-ia/backend/current/ops/deploy/docker-compose.yml up -d --force-recreate backend && curl -fsS http://127.0.0.1:8080/docs >/dev/null
